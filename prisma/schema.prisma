// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

model User {
  id           String    @id @default(uuid())
  username     String?   @unique
  email        String?   @unique
  deviceId     String?   @unique @map("device_id")
  isGuest      Boolean   @default(false) @map("is_guest")
  bondingScore Float     @default(0.0) @map("bonding_score")
  accounts     Account[]
  sessions     Session[]
  memories     Memory[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  dpe          Json?     @map("dpe")
  behavioralBaseline BehavioralBaseline?

  @@map("users")
}

model OtpVerification {
  id        String   @id @default(uuid())
  email     String
  codeHash  String   @map("code_hash")
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("otp_verifications")
}

model BehavioralBaseline {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  typicalActiveStart Int      @default(6)  @map("typical_active_start") // 0-23
  typicalActiveEnd   Int      @default(22) @map("typical_active_end")   // 0-23
  timezone          String   @default("UTC")
  lastUpdated       DateTime @default(now()) @map("last_updated")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("behavioral_baselines")
}

model Memory {
  id               String                 @id @default(uuid())
  userId           String                 @map("user_id")
  content          String                 @db.Text
  embedding        Unsupported("vector(768)")?
  metadata         Json?
  sensitivityLevel Int                    @default(1) @map("sensitivity_level")
  isDeleted        Boolean                @default(false) @map("is_deleted")
  createdAt        DateTime               @default(now()) @map("created_at")

  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("memories")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  passwordHash      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id          String    @id @default(uuid())
  userId      String
  isIncognito Boolean   @default(false)
  isDeleted   Boolean   @default(false) @map("is_deleted")
  messages    Message[]
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("sessions")
}

model Message {
  id        String   @id @default(uuid())
  sessionId String
  role      Role     @default(USER)
  content   String   @db.Text
  metadata  Json?
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("messages")
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}
