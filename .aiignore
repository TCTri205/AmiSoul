# AI Exclusion Patterns
# Prevent AI agents from reading or searching sensitive files

.env
.env.local
.env.development
.env.production
.env.test
.env.development.local
.env.test.local
.env.production.local
.env*.local
.env*.backup
.env*.old

# Credentials and keys
**/*.pem
**/*.key
**/id_rsa
**/id_dsa
**/id_ecdsa
**/id_ed25519

# Do NOT ignore .env.example
!.env.example
