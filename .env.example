# App configuration
PORT=3000
NODE_ENV=development

# Database configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=amisoul
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amisoul?schema=public"

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# AI Configuration
# Support comma-separated lists for key rotation (e.g., key1,key2)
GROQ_API_KEYS=your_groq_api_key_here
GEMINI_API_KEYS=your_gemini_api_key_here


# Security Configuration
ENCRYPTION_KEY=your_32_character_secret_key_here

JWT_SECRET=
JWT_EXPIRATION=